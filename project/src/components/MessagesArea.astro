---
import Message from './Message.astro';
---

<div class="messages-area" id="messagesArea">
  <Message 
    sender="agent" 
    text="¡Hola! 👋 Soy tu asistente A2A. Selecciona un agente arriba y empecemos a chatear. Puedes enviar texto e imágenes."
  />
</div>

<style>
  .messages-area {
    flex: 1;
    padding: 20px;
    overflow-y: auto;
    scroll-behavior: smooth;
  }
</style>