---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="A2A Agent Chat Interface" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>
    <nav class="main-nav">
      <a href="/home" class="nav-link">Inicio</a>
      <a href="/agents" class="nav-link">Agentes</a>
      <a href="/conversation" class="nav-link">Conversación</a>
      <a href="/event_list" class="nav-link">Eventos</a>
      <a href="/task_list" class="nav-link">Tareas</a>
      <a href="/settings" class="nav-link">Configuración</a>
    </nav>
    <slot />
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    --secondary-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    --accent-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    --dark-bg: #0f0f23;
    --card-bg: rgba(255, 255, 255, 0.05);
    --glass-bg: rgba(255, 255, 255, 0.1);
    --text-primary: #ffffff;
    --text-secondary: #a0a0b3;
    --border-color: rgba(255, 255, 255, 0.1);
    --shadow-glow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--dark-bg);
    color: var(--text-primary);
    min-height: 100vh;
    background-image: 
      radial-gradient(circle at 20% 20%, rgba(102, 126, 234, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(118, 75, 162, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 40% 60%, rgba(240, 147, 251, 0.05) 0%, transparent 50%);
    overflow-x: hidden;
  }

  .main-nav {
    display: flex;
    gap: 18px;
    background: var(--glass-bg);
    padding: 18px 32px;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 32px;
    border-radius: 0 0 18px 18px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    justify-content: center;
  }
  .nav-link {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 1.1rem;
    padding: 6px 18px;
    border-radius: 8px;
    transition: background 0.2s, color 0.2s;
  }
  .nav-link:hover, .nav-link.active {
    background: var(--primary-gradient);
    color: #fff;
  }
</style>